# Copy to .env.local and fill in values.

# Site URL (used for redirects)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Set to "true" to show the FAST LOGIN (DEV) button on the login page
NEXT_PUBLIC_DEV_LOGIN=false
# Default UI style on first visit — "glass" or "pro"
NEXT_PUBLIC_DEFAULT_UI_STYLE=glass

# Default dashboard variant when uiStyle=pro — "glass" or "pro"
NEXT_PUBLIC_DEFAULT_DASHBOARD_STYLE=glass

# Better Auth
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=replace-with-long-random-string

# MongoDB
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=publeader

# SMTP (leave empty in dev to log OTP to console)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@publeader.local

# Cloudinary — signed direct uploads from mobile/web
# Get values from https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Public name exposed to clients (same as CLOUDINARY_CLOUD_NAME)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=

# Stripe — invoice payments (AD3)
# Get keys from https://dashboard.stripe.com/apikeys
# Webhook secret comes from the endpoint you create at /dashboard/webhooks
# pointed at <NEXT_PUBLIC_SITE_URL>/api/stripe/webhook
# (events: checkout.session.completed, payment_intent.payment_failed,
# charge.refunded, charge.dispute.created, charge.dispute.closed).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
